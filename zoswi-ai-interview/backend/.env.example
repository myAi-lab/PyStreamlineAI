APP_NAME=ZoSwi AI Platform
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zoswi
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/zoswi
DATABASE_SCHEMA=public
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=30
REFRESH_TOKEN_EXP_DAYS=7

AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_ALLOW_MOCK_PROVIDER=true

UPLOAD_MAX_SIZE_BYTES=5000000
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=storage/files
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

RATE_LIMIT_REQUESTS_PER_MINUTE=120
INTERVIEW_MAX_TURNS=8
LIVE_INTERVIEW_APP_URL=http://localhost:3000/interview
INTERVIEW_LAUNCH_SECRET=
INTERVIEW_LAUNCH_TTL_SECONDS=900
INTERVIEW_LAUNCH_ISSUER=zoswi-web
INTERVIEW_LAUNCH_AUDIENCE=zoswi-interview-launch

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/linkedin/callback
OAUTH_STATE_EXP_MINUTES=10
OAUTH_BRIDGE_EXP_MINUTES=5
