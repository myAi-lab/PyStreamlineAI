APP_NAME=ZoSwi AI Interview API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app

# Supabase Transaction Pooler example:
# postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

OPENAI_API_KEY=
OPENAI_API_SETTING_KEY=ZOSWI_AI_API_KEY
DB_API_KEY_CACHE_TTL_SECONDS=30
STT_MODEL=gpt-4o-mini-transcribe
STT_FALLBACK_MODELS=whisper-1
LLM_MODEL=gpt-4.1-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=cedar

MAX_QUESTIONS_PER_INTERVIEW=5
ANSWER_TIME_LIMIT_SECONDS=120
INTERVIEW_DURATION_SECONDS=1800
STORAGE_DIR=storage

# Optional for future Supabase Storage/Auth integration
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=interview-audio
